local RADAR_PX    = 200   -- radar circle diameter in pixels
local RADAR_RANGE = 500   -- world studs radius

local function destroyRadar()
    isRadarEnabled = false
    if radarConn then radarConn:Disconnect(); radarConn = nil end
    if radarGui  then pcall(function() radarGui:Destroy() end); radarGui = nil end
    _radarBlips = {}
end

local function createRadar()
    destroyRadar()
    isRadarEnabled = true
    local pg = player:FindFirstChild("PlayerGui") or player:WaitForChild("PlayerGui")
    local sg = Instance.new("ScreenGui")
    sg.Name = "Abaddon_Radar"
    sg.IgnoreGuiInset = true
    sg.ResetOnSpawn = false
    sg.DisplayOrder = 800
    sg.Parent = pg
    radarGui = sg

    -- Background circle
    local bg = Instance.new("Frame", sg)
    bg.Name = "RadarBg"
    bg.Size = UDim2.new(0, RADAR_PX, 0, RADAR_PX)
    bg.AnchorPoint = Vector2.new(1, 0.5)
    bg.Position = UDim2.new(1, -10, 0.5, 0)
    bg.BackgroundColor3 = menuBgColor
    bg.BackgroundTransparency = menuBgTransparency
    bg.BorderSizePixel = 0
    bg.ClipsDescendants = true
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 14)
    local ring = Instance.new("UIStroke", bg)
    ring.Color = currentThemeColor
    ring.Thickness = 1.5

    -- Crosshair lines (theme color)
    local function mkLine(h)
        local l = Instance.new("Frame", bg)
        l.BackgroundColor3 = currentThemeColor
        l.BackgroundTransparency = 0.7
        l.BorderSizePixel = 0
        l.AnchorPoint = Vector2.new(0.5, 0.5)
        l.Position = UDim2.new(0.5, 0, 0.5, 0)
        l.Size = h and UDim2.new(1, 0, 0, 1) or UDim2.new(0, 1, 1, 0)
    end
    mkLine(true); mkLine(false)

    -- Self dot (theme color, center)
    local selfDot = Instance.new("Frame", bg)
    selfDot.Size = UDim2.new(0, 7, 0, 7)
    selfDot.AnchorPoint = Vector2.new(0.5, 0.5)
    selfDot.Position = UDim2.new(0.5, 0, 0.5, 0)
    selfDot.BackgroundColor3 = currentThemeColor
    selfDot.BorderSizePixel = 0
    selfDot.ZIndex = 5
    Instance.new("UICorner", selfDot).CornerRadius = UDim.new(1, 0)

    local half = RADAR_PX / 2

    -- Update loop: 10 fps is smooth enough for radar
    local lastTick = 0
    radarConn = RunService.Heartbeat:Connect(function()
        if not isRadarEnabled then return end
        local now = tick()
        if now - lastTick < 0.05 then return end
        lastTick = now

        local myChar = player.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end

        local myPos = myRoot.Position
        local seen  = {}

        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= player and p.Character then
                local root = p.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    local diff = root.Position - myPos
                    -- Camera-relative direction
                    local myCF = myRoot.CFrame
                    local relX = myCF.RightVector:Dot(diff)
                    local relZ = myCF.LookVector:Dot(diff)
                    local dist = math.sqrt(relX*relX + relZ*relZ)
                    if dist <= RADAR_RANGE then
                        local scale = math.min(dist / RADAR_RANGE, 1)
                        local nx = (relX / math.max(dist, 0.01)) * scale * half
                        local nz = (relZ / math.max(dist, 0.01)) * scale * half
                        -- dot color = team color, fallback = theme color
                        local col = p.Team and p.TeamColor.Color or currentThemeColor
                        local dot = _radarBlips[p]
                        if not dot or not dot.Parent then
                            dot = Instance.new("Frame", bg)
                            dot.Size = UDim2.new(0, 7, 0, 7)
                            dot.AnchorPoint = Vector2.new(0.5, 0.5)
                            dot.BorderSizePixel = 0
                            dot.ZIndex = 4
                            Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
                            _radarBlips[p] = dot
                        end
                        dot.BackgroundColor3 = col
                        -- Smooth lerp to new position
                        local curX = dot.Position.X.Offset
                        local curY = dot.Position.Y.Offset
                        local tX = math.floor(nx)
                        local tY = math.floor(-nz)
                        local lerpF = 0.18  -- lower = smoother
                        dot.Position = UDim2.new(0.5, math.floor(curX + (tX - curX) * lerpF),
                                                 0.5, math.floor(curY + (tY - curY) * lerpF))
                        dot.Visible = true
                        seen[p] = true
                    end
                end
            end
        end

        for p, dot in pairs(_radarBlips) do
            if not seen[p] then dot.Visible = false end
        end
    end)

    -- Drag: only when menu visible
    local drag, dragStart, dragPos0 = false, nil, nil
    bg.InputBegan:Connect(function(inp)
        if not isMenuOpen then return end
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            drag = true; dragStart = inp.Position; dragPos0 = bg.Position
        end
    end)
    bg.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            drag = false
            savedLayoutPositions["RadarBg"] = {
                bg.Position.X.Scale, bg.Position.X.Offset,
                bg.Position.Y.Scale, bg.Position.Y.Offset
            }
        end
    end)
    UIS.InputChanged:Connect(function(inp)
        if drag and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local d = inp.Position - dragStart
            bg.Position = UDim2.new(
                dragPos0.X.Scale, dragPos0.X.Offset + d.X,
                dragPos0.Y.Scale, dragPos0.Y.Offset + d.Y)
        end
    end)

    -- Restore saved position
    local saved = savedLayoutPositions["RadarBg"]
	if saved and #saved == 4 then
    	bg.Position = UDim2.new(saved[1], saved[2], saved[3], saved[4])
	end
end

local function toggleRadar(state)
    if state then createRadar() else destroyRadar() end
end


