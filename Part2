-- === MENU ANIMATION ===
function toggleMenuWithAnimation(state)
    -- Only actual menu windows animate in/out with menu
    local windows = {visualWin, autokitWin, themeWin, configWin, spectateWin, uninjectBtn, discordBtn, bedMinigameBtn, unlockBtn}
    -- HUDs that are always visible (independent of menu)
    local alwaysVisibleHuds = {
        {gui = serverHpGui,   enabled = function() return isServerHpEnabled and isServerHpVisible end},
        {gui = staffStatsGui, enabled = function() return isStaffStatsEnabled and isStaffStatsVisible end},
        {gui = targetInfoGui, enabled = function() return isTargetInfoEnabled end},
        {gui = friendHpGui,   enabled = function() return isFriendHpEnabled and isFriendHpVisible end},
    }
    if state then
        toggleBlur(true)
        for _, frame in pairs(windows) do
            if frame then
                if not savedWindowPositions[frame] then savedWindowPositions[frame] = frame.Position end
                local properPos = savedWindowPositions[frame]
                frame.Visible = true
                frame.Position = UDim2.new(properPos.X.Scale, properPos.X.Offset, 1.5, 0)
                TS:Create(frame, TweenInfo.new(0.8, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = properPos}):Play()
            end
        end
    else
        toggleBlur(false)
        for _, frame in pairs(windows) do
            if frame then
                if not savedWindowPositions[frame] then savedWindowPositions[frame] = frame.Position end
                local properPos = savedWindowPositions[frame]
                local offScreenPos = UDim2.new(properPos.X.Scale, properPos.X.Offset, 1.5, 0)
                TS:Create(frame, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = offScreenPos}):Play()
            end
        end
    end
    -- Keep HUDs visible regardless of menu state
    for _, hud in ipairs(alwaysVisibleHuds) do
        if hud.gui then
            hud.gui.Visible = hud.enabled()
        end
    end
end

