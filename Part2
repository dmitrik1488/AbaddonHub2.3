-- === PRIME MODE ===
local function primeModeCleanup()
    isPrimeModeEnabled = false
    -- Disconnect player connections
    for _, c in pairs(primeModeCharConns) do pcall(function() c:Disconnect() end) end
    table.clear(primeModeCharConns)
    if primeModePlayerAddedConn then
        pcall(function() primeModePlayerAddedConn:Disconnect() end)
        primeModePlayerAddedConn = nil
    end
    -- Remove billboards
    for _, b in pairs(primeModeBillboards) do pcall(function() b:Destroy() end) end
    table.clear(primeModeBillboards)
    -- Unbind camera effect
    pcall(function() RS:UnbindFromRenderStep("TrippyCameraEffect") end)
    -- Restore camera FOV
    pcall(function() if primeModeOrigFov then camera.FieldOfView = primeModeOrigFov end end)
    primeModeOrigFov = nil
    -- Destroy lighting effects
    if primeModeColorCorr then pcall(function() primeModeColorCorr:Destroy() end); primeModeColorCorr = nil end
    if primeModeBlur       then pcall(function() primeModeBlur:Destroy() end);       primeModeBlur = nil end
    if primeModeSky        then pcall(function() primeModeSky:Destroy() end);        primeModeSky = nil end
    -- Stop and destroy sound
    if primeModeSound then
        pcall(function() primeModeSound:Stop() end)
        pcall(function() primeModeSound:Destroy() end)
        primeModeSound = nil
    end
    -- Destroy screen GUI
    if primeModeScreenGui then
        pcall(function() primeModeScreenGui:Destroy() end)
        primeModeScreenGui = nil
    end
    -- Restore sound service settings
    pcall(function() game:GetService("SoundService").AmbientReverb = Enum.ReverbType.NoReverb end)
end

local function primeModeAddBillboard(character)
    if not isPrimeModeEnabled then return end
    if character == player.Character then return end
    local root = character:FindFirstChild("HumanoidRootPart")
        or character:FindFirstChild("UpperTorso")
        or character:FindFirstChild("Torso")
    if not root then return end
    local bb = Instance.new("BillboardGui")
    bb.Size = UDim2.new(5,0,5,0)
    bb.AlwaysOnTop = true
    local img = Instance.new("ImageLabel", bb)
    img.Size = UDim2.new(1,0,1,0)
    img.Image = "rbxthumb://type=Asset&id=12983135493&w=420&h=420"
    img.BackgroundTransparency = 1
    bb.Parent = root
    table.insert(primeModeBillboards, bb)
end

local function togglePrimeMode(state)
    if state == isPrimeModeEnabled then return end
    if not state then
        primeModeCleanup()
        pcall(function() showNotification("Prime Mode", { { text = "Disabled", color = Color3.fromRGB(255,120,120) } }) end)
        return
    end
    isPrimeModeEnabled = true
    primeModeOrigFov = camera.FieldOfView  -- save before any change
    pcall(function() showNotification("Prime Mode", { { text = "Enabled", color = Color3.fromRGB(120,255,120) } }) end)

    -- Sound service
    if primeModeEcho then pcall(function() game:GetService("SoundService").AmbientReverb = Enum.ReverbType.Cave end) end

    -- ColorCorrection
    primeModeColorCorr = Instance.new("ColorCorrectionEffect")
    primeModeColorCorr.Parent = Lighting

    -- Blur
    primeModeBlur = Instance.new("BlurEffect")
    primeModeBlur.Size = 4
    primeModeBlur.Parent = Lighting

    -- Sky
    primeModeSky = Instance.new("Sky")
    local skyTex = "rbxthumb://type=Asset&id=16229312490&w=420&h=420"
    primeModeSky.SkyboxBk = skyTex; primeModeSky.SkyboxDn = skyTex
    primeModeSky.SkyboxFt = skyTex; primeModeSky.SkyboxLf = skyTex
    primeModeSky.SkyboxRt = skyTex; primeModeSky.SkyboxUp = skyTex
    primeModeSky.Parent = Lighting

    -- Sound
    local snd = Instance.new("Sound")
    snd.SoundId = "rbxassetid://99938454010795"
    snd.PlaybackSpeed = 0.2
    snd.Volume = primeModeVolume
    snd.Looped = true
    snd.RollOffMaxDistance = 0  -- audible everywhere, no 3D falloff
    snd.Parent = game:GetService("SoundService")
    local dist2 = Instance.new("DistortionSoundEffect"); dist2.Level = 1; dist2.Parent = snd
    local eq2 = Instance.new("EqualizerSoundEffect"); eq2.LowGain=10; eq2.MidGain=10; eq2.HighGain=10; eq2.Parent = snd
    primeModeSound = snd
    -- Wait for asset to load then play
    task.spawn(function()
        local ok = pcall(function()
            if not snd.IsLoaded then snd.Loaded:Wait() end
        end)
        if isPrimeModeEnabled and primeModeSound == snd then
            pcall(function() snd:Play() end)
        end
    end)

    -- Screen GUI (crosshair)
    local pg = player:FindFirstChild("PlayerGui") or player:WaitForChild("PlayerGui")
    primeModeScreenGui = Instance.new("ScreenGui")
    primeModeScreenGui.DisplayOrder = 999999
    primeModeScreenGui.ResetOnSpawn = false
    primeModeScreenGui.Parent = pg
    local ch = Instance.new("ImageLabel", primeModeScreenGui)
    ch.Size = UDim2.new(0,60,0,60)
    ch.Position = UDim2.new(0.5,0,0.48,0)
    ch.AnchorPoint = Vector2.new(0.5,0.5)
    ch.Image = "rbxthumb://type=Asset&id=15233722645&w=420&h=420"
    ch.BackgroundTransparency = 1
    ch.ZIndex = 999999

    -- Billboards for existing players
    for _, p2 in pairs(Players:GetPlayers()) do
        if p2 ~= player and p2.Character then
            primeModeAddBillboard(p2.Character)
        end
        local conn = p2.CharacterAdded:Connect(function(char)
            task.wait(0.5); primeModeAddBillboard(char)
        end)
        table.insert(primeModeCharConns, conn)
    end
    primeModePlayerAddedConn = Players.PlayerAdded:Connect(function(p2)
        local conn = p2.CharacterAdded:Connect(function(char)
            task.wait(0.5); primeModeAddBillboard(char)
        end)
        table.insert(primeModeCharConns, conn)
    end)

    -- Camera chaos loop
    local timePassed = 0
    RS:BindToRenderStep("TrippyCameraEffect", Enum.RenderPriority.Camera.Value + 1, function(dt)
        if not isPrimeModeEnabled then
            RS:UnbindFromRenderStep("TrippyCameraEffect")
            pcall(function() if primeModeOrigFov then camera.FieldOfView = primeModeOrigFov; primeModeOrigFov = nil end end)
            return
        end
        timePassed = timePassed + dt
        local r = (math.sin(timePassed * 1.5) + 1) / 2
        local g = (math.sin(timePassed * 2.2) + 1) / 2
        local b2 = (math.sin(timePassed * 3.1) + 1) / 2
        if primeModeColorCorr then
            primeModeColorCorr.TintColor = Color3.new(r, g, b2)
            primeModeColorCorr.Contrast = 0.4 + math.sin(timePassed * 4) * 0.3
        end
        local sk = primeModeShake
        if primeModeChangeFov then camera.FieldOfView = 70 + math.sin(timePassed * 3) * 20 * sk end
        local tiltZ  = math.sin(timePassed * 2)  * 5   * sk
        local shakeX = math.sin(timePassed * 15) * 0.4 * sk
        local shakeY = math.cos(timePassed * 12) * 0.4 * sk
        camera.CFrame = camera.CFrame * CFrame.Angles(math.rad(shakeX), math.rad(shakeY), math.rad(tiltZ))
    end)
end


-- === WORLD COLOR ===






local function wcDestroy()
    wcEnabled = false
    if wcColorCorrect then
        pcall(function() wcColorCorrect:Destroy() end)
        wcColorCorrect = nil
    end
end

local function wcApply()
    local L = game:GetService("Lighting")
    -- Color correction
    if not wcColorCorrect then
        -- Remove any previous
        local old = L:FindFirstChild("AbaddonWorldColor")
        if old then old:Destroy() end
        wcColorCorrect = Instance.new("ColorCorrectionEffect")
        wcColorCorrect.Name = "AbaddonWorldColor"
        wcColorCorrect.Parent = L
    end
    -- Blend tint with white based on intensity
    local t = wcIntensity
    local r = math.floor(255 * (1-t) + wcColorR * t + 0.5)
    local g = math.floor(255 * (1-t) + wcColorG * t + 0.5)
    local b2 = math.floor(255 * (1-t) + wcColorB * t + 0.5)
    wcColorCorrect.TintColor = Color3.fromRGB(r, g, b2)
    wcColorCorrect.Enabled = true
end

local function toggleWorldColor(state)
    wcEnabled = state
    if state then
        wcApply()
    else
        if wcColorCorrect then
            pcall(function() wcColorCorrect.Enabled = false end)
        end
    end
end


-- === HIT CHAMS ===
local function hitChamsFlash(p)
    if _hitChamsActive[p] then return end
    local char = p.Character
    if not char then return end
    _hitChamsActive[p] = true
    local col = Color3.fromRGB(hitChamsR, hitChamsG, hitChamsB)
    local transp = math.clamp(1 - hitChamsIntensity, 0, 0.9)
    local hl = Instance.new("Highlight")
    hl.Name = "AbaddonHitChams"
    hl.FillColor = col
    hl.OutlineColor = col
