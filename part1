    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

local function makeResizable(frame, handle)
    local resizing, dragStart, startSize
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and isMenuOpen then
            resizing = true; dragStart = input.Position; startSize = frame.AbsoluteSize
        end
    end)
    handle.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then resizing = false end end)
    UIS.InputChanged:Connect(function(input)
        if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            frame.Size = UDim2.new(0, math.max(200, startSize.X + delta.X), 0, math.max(100, startSize.Y + delta.Y))
        end
    end)
end

local visualWin, themeWin = nil, nil
local function taliyahCalcNext()
    local nextBase = taliyahBasePriceIdx + 10
    local nextMax  = math.min(taliyahMaxIdx + 43, 1200)
    local minP = nextBase + (-nextBase / 2)
    local maxP = nextBase + nextMax
    return math.floor(minP), math.floor(maxP)
end

local function taliyahRefreshRows()
    if not taliyahGui then return end
    local list = taliyahGui:FindFirstChild("ListContainer")
    if not list then return end
    for _, c in list:GetChildren() do
        if c:IsA("Frame") then c:Destroy() end
    end

    local currentPrice    = workspace:GetAttribute("ChickenPrice")
    local currentCurrency = tostring(workspace:GetAttribute("ChickenCurrency") or "")
    local isEmerald       = currentCurrency:lower():find("emerald") ~= nil
    local currStr         = isEmerald and "EMERALD" or "IRON"
    local minP, maxP      = taliyahCalcNext()

    local function makeRow(order, text, textColor)
        local r = Instance.new("Frame", list)
        r.LayoutOrder = order
        r.Size = UDim2.new(1, 0, 0, 25)
        r.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        r.BackgroundTransparency = 0.5
        r.BorderSizePixel = 0
        Instance.new("UICorner", r).CornerRadius = UDim.new(0, 4)
        local lbl = Instance.new("TextLabel", r)
        lbl.Size = UDim2.new(1, -10, 1, 0)
        lbl.Position = UDim2.new(0, 10, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.TextColor3 = textColor
        lbl.Font = Enum.Font.GothamBold
        lbl.TextSize = 13
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Text = text
        return lbl
    end

    local priceText, nextText
    if currentPrice ~= nil then
        priceText = "Price: " .. math.floor(currentPrice) .. " " .. currStr
        nextText  = "Next: "  .. minP .. " - " .. maxP
    else
        priceText = "Price: waiting..."
        nextText  = "Next:  waiting..."
    end

    local warnText, warnColor
    if isEmerald then
        warnColor = Color3.fromRGB(46, 204, 113)
        warnText  = "Currency: EMERALD"
    elseif maxP >= 100 then
        warnColor = Color3.fromRGB(255, 85, 85)
        warnText  = "WARNING: Emerald ~10%"
    else
        warnColor = Color3.fromRGB(150, 150, 150)
        warnText  = "Emerald chance: low"
    end

    makeRow(1, "Wave: " .. taliyahWave, Color3.new(1, 1, 1))
    makeRow(2, priceText,               Color3.new(1, 1, 1))
    makeRow(3, nextText,                Color3.fromRGB(255, 170, 0))
    makeRow(4, warnText,                warnColor)

    taliyahGui.Size = UDim2.new(0, 250, 0, 35 + 4 * 30 + 5)
    list.CanvasSize = UDim2.new(0, 0, 0, 4 * 30)
end

local function taliyahUpdateGui()
    if not taliyahGui or not isTaliyahEnabled then return end
    if workspace:GetAttribute("ChickenPrice") == nil then return end

    if taliyahIsInitialized then
        taliyahWave         = taliyahWave + 1
        taliyahBasePriceIdx = taliyahBasePriceIdx + 10
        taliyahMaxIdx       = math.min(taliyahMaxIdx + 43, 1200)
        getgenv()._taliyahWave = taliyahWave
        getgenv()._taliyahBase = taliyahBasePriceIdx
        getgenv()._taliyahMax  = taliyahMaxIdx
    else
        taliyahIsInitialized = true
    end
    taliyahRefreshRows()
end

local function taliyahConnectSignal()
    if taliyahConnection then
        pcall(function() taliyahConnection:Disconnect() end)
        taliyahConnection = nil
    end
    pcall(function()
        taliyahConnection = workspace:GetAttributeChangedSignal("ChickenPrice"):Connect(function()
            if isTaliyahEnabled then taliyahUpdateGui() end
        end)
    end)
end

-- Apply saved layout position to a frame if one exists
local function applyLayoutPos(frame)
    if not frame or not frame.Name then return end
    local p = savedLayoutPositions[frame.Name]
    if p then
        local newPos = UDim2.new(p[1], p[2], p[3], p[4])
        frame.Position = newPos
        savedWindowPositions[frame] = newPos
    end
end

