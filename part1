local function updateFriendHp()
    if not isFriendHpEnabled or not isAbaddonHudEnabled or not friendHpGui or not isFriendHpVisible then
        if friendHpGui then friendHpGui.Visible = false end; return
    end
    local anyVisible = false
    for i = 1, 3 do
        local slot = friendHpGui:FindFirstChild("Slot"..i)
        if slot then
            local nick = friendTargetNames[i] or ""
            if nick == "" then
                slot.Visible = false
            else
                local target = nil
                for _, p in pairs(game.Players:GetPlayers()) do
                    if string.find(string.lower(p.Name), string.lower(nick), 1, true)
                    or string.find(string.lower(p.DisplayName), string.lower(nick), 1, true) then
                        target = p; break
                    end
                end
                if target and target.Character and target.Character:FindFirstChild("Humanoid") then
                    local hum = target.Character.Humanoid
                    if hum.Health > 0 then
                        slot.Visible = true
                        anyVisible = true
                        local nameLbl = slot:FindFirstChild("FriendName")
                        if nameLbl then nameLbl.Text = target.DisplayName end
                        local bg = slot:FindFirstChild("HPBarBG")
                        if bg then
                            local fill = bg:FindFirstChild("HPFill")
                            local txt = bg:FindFirstChild("HPText")
                            local ratio = math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1)
                            if fill then
                                fill.Size = UDim2.new(ratio, 0, 1, 0)
                                fill.BackgroundColor3 = ratio > 0.6 and Color3.fromRGB(60,220,60)
                                    or ratio > 0.3 and Color3.fromRGB(255,190,0) or Color3.fromRGB(220,40,40)
                            end
                            if txt then txt.Text = math.floor(hum.Health).." / "..math.floor(hum.MaxHealth) end
                        end
                    else slot.Visible = false end
                else slot.Visible = false end
            end
        end
    end
    -- Resize frame to fit visible slots
    local visCount = 0
    for i = 1, 3 do
        local slot = friendHpGui:FindFirstChild("Slot"..i)
        if slot and slot.Visible then visCount = visCount + 1 end
    end
    friendHpGui.Visible = (visCount > 0)
    if visCount > 0 then
        friendHpGui.Size = UDim2.new(0, 210, 0, visCount * 54 + 8)
    end
end

local function toggleFriendHp(state)
    isFriendHpEnabled = state
    if state then
        createFriendHpHUD()
        friendHpConnection = RS.RenderStepped:Connect(updateFriendHp)
    else
        if friendHpConnection then friendHpConnection:Disconnect(); friendHpConnection = nil end
        if friendHpGui then friendHpGui:Destroy(); friendHpGui = nil end
    end
end

