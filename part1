local function checkBedAlarm()
    if not isBedAlarmEnabled or not bedAlarmPos or alarmCooldown then 
        stopAlarm()
        return 
    end
    -- Don't run if local player is dead (prevents ally detection after death/spectate)
    local myChar = player.Character
    local myHum = myChar and myChar:FindFirstChild("Humanoid")
    if not myHum or myHum.Health <= 0 then
        stopAlarm()
        return
    end
    local intruderFound = false
    local currentIntruders = {} 
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= player then
            local isEnemy = true
            if player.Team and p.Team and player.Team == p.Team then
                isEnemy = false
            end
            if isEnemy and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") then
                local hum = p.Character.Humanoid
                if hum.Health > 0 then
                    local root = p.Character.HumanoidRootPart
                    local enemyPos = root.Position
                    local distH = (Vector3.new(enemyPos.X, 0, enemyPos.Z) - Vector3.new(bedAlarmPos.X, 0, bedAlarmPos.Z)).Magnitude
                    local distV = enemyPos.Y - bedAlarmPos.Y
                    if distH <= bedAlarmRadius and distV >= -100 and distV <= 200 then
                        intruderFound = true
                        currentIntruders[p] = true
                        -- Notify once per player (cooldown 8s)
                        local now = tick()
                        if not lastBedAlarmNotif[p.Name] or (now - lastBedAlarmNotif[p.Name]) > 8 then
                            lastBedAlarmNotif[p.Name] = now
                            local nameColor = Color3.new(1, 1, 1)
                            if p.Team then nameColor = p.Team.TeamColor.Color end
                            task.spawn(function()
                                showNotification("Bed Alarm", {
                                    { text = "Someone is near your base!", color = Color3.new(1, 0.85, 0.85) },
                                    { text = p.DisplayName, color = nameColor },
                                })
                            end)
                        end
                    end
                end
            end
        end
    end
    updateIntruderHighlights(currentIntruders)
    if not bedAlarmGui then createBedAlarmAlert() end
    if intruderFound then
        bedAlarmGui.AlertFrame.Visible = true
        if not bedAlarmSound or not bedAlarmSound.Parent then
             bedAlarmSound = Instance.new("Sound", game.SoundService)
             bedAlarmSound.Name = ALARM_SOUND_NAME
             bedAlarmSound.SoundId = alarmSoundId
             bedAlarmSound.Volume = bedAlarmVolume
             bedAlarmSound.Looped = true
        end
        if not bedAlarmSound.IsPlaying then bedAlarmSound:Play() end
    else
        stopAlarm()
    end
end

