local function autoFishLoop()
    if not isFisherEnabled then 
        if isClickingFish then setMouseState(false) end
        return 
    end

    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return end

    local foundGame = false

    for _, obj in ipairs(playerGui:GetDescendants()) do
        if obj:IsA("ImageLabel") and obj.Image == TARGET_FISH_IMAGE then
            local fishZone = obj.Parent
            if fishZone and fishZone:IsA("Frame") then
                local container = fishZone.Parent
                if container then
                    local marker = nil
                    for _, child in ipairs(container:GetChildren()) do
                        if child:IsA("Frame") and child.ZIndex == 3 then
                            marker = child
                            break
                        end
                    end

                    if marker then
                        foundGame = true
                        local markerPos = marker.AbsolutePosition.X
                        local zonePos = fishZone.AbsolutePosition.X
                        local zoneSize = fishZone.AbsoluteSize.X
                        local zoneCenter = zonePos + (zoneSize / 2)
                        local markerCenter = markerPos + (marker.AbsoluteSize.X / 2)

                        if markerCenter < zoneCenter then
                            setMouseState(true)
                        else
                            setMouseState(false)
                        end
                    end
                end
            end
        end
    end

    if not foundGame and isClickingFish then
        setMouseState(false)
    end
end

