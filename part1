                            Instance.new("UICorner", outer).CornerRadius = UDim.new(0, 5)

                            local inner = Instance.new("Frame", bb)
                            inner.Name = "InnerDiamond"
                            inner.AnchorPoint = Vector2.new(0.5, 0)
                            inner.Position = UDim2.new(0.5, 0, 0, 37)
                            inner.Size = UDim2.new(0, math.floor(14), 0, math.floor(14))
                            inner.Rotation = 45
                            inner.BackgroundColor3 = Color3.new(1, 1, 1)
                            inner.BackgroundTransparency = math.min(0.5 + 0.2, 1)
                            inner.BorderSizePixel = 0
                            Instance.new("UICorner", inner).CornerRadius = UDim.new(0, 3)
                        end

                    else
                        -- BB exists: update dynamic values only
                        bb.Adornee = root
                        local hpSec = bb:FindFirstChild("HpSection")
                        if hpSec then
                            hpSec.Visible = isEspHpEnabled
                            local t = hpSec:FindFirstChild("HpText")
