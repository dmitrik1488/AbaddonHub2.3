-- === AUTOKIT LOGIC ===

local function isNearBrokenTable(root)
    local tableObj = workspace:FindFirstChild("broken_enchant_table", true)
    if not tableObj then return false end

    local targetPos = nil
    if tableObj:IsA("Model") then
        local prim = tableObj.PrimaryPart or tableObj:FindFirstChildWhichIsA("BasePart")
        if prim then targetPos = prim.Position else targetPos = tableObj:GetPivot().Position end
    elseif tableObj:IsA("BasePart") then
        targetPos = tableObj.Position
    end

    if targetPos and root then
        return (root.Position - targetPos).Magnitude < 15
    end
    return false
end

local function shouldIgnore(obj)
    if not obj then return true end
    if obj.Name == "broken_enchant_table" then return true end
    if obj.Parent and obj.Parent.Name == "broken_enchant_table" then return true end
    return false
end

local function isElderTarget(name)
    local lowerName = string.lower(name)
    for _, keyword in ipairs(ELDER_KEYWORDS) do
        if string.find(lowerName, string.lower(keyword)) then
            return true
        end
    end
    return false
end

