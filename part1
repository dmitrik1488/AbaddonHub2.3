                        bb.AlwaysOnTop = true
                        bb.Size = UDim2.new(0, bbW, 0, bbH)
                        bb.StudsOffset = Vector3.new(0, bbStudY, 0)
                        bb:SetAttribute("EspMode", currentEspMode)
