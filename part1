-- === SERVER HITBOX ===
local function destroyServerHitboxClone()
    if serverHitboxClone then
        serverHitboxClone:Destroy()
        serverHitboxClone = nil
    end
    serverPoseHistory = {}
end

local function createServerHitboxClone()
    destroyServerHitboxClone()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local box = Instance.new("Part")
    box.Name = "Abaddon_ServerBox"
    box.Anchored = true
    box.CanCollide = false
    box.CanQuery = false
    box.CanTouch = false
    box.CastShadow = false
    box.Size = Vector3.new(3, 6, 3)
    box.Material = Enum.Material.Neon
    box.Color = currentThemeColor
    box.Transparency = 0.6
    box.Parent = workspace
    serverHitboxClone = box
end

local function serverHitboxRecord()
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not char or not hrp then return end
    local now = tick()
    table.insert(serverPoseHistory, {
        time  = now,
        pivot = hrp.CFrame,
    })
    while #serverPoseHistory > 0 and (now - serverPoseHistory[1].time) > 2 do
        table.remove(serverPoseHistory, 1)
    end
end

local function serverHitboxApply()
    if not serverHitboxClone then return end

    local pingDelay = 0
    pcall(function()
        local statsService = game:GetService("Stats")
        local net = statsService:FindFirstChild("Network")
        local ssi = net and net:FindFirstChild("ServerStatsItem")
        local dp = ssi and ssi:FindFirstChild("Data Ping")
        if dp then pingDelay = math.clamp(dp:GetValue() / 500, 0, 2) end
    end)

    local now = tick()
    local targetTime = now - pingDelay
    local pose = nil
    for i = #serverPoseHistory, 1, -1 do
        if serverPoseHistory[i].time <= targetTime then
            pose = serverPoseHistory[i]; break
        end
    end

    if pose then
        serverHitboxClone.CFrame = pose.pivot
    end

    -- Синхронізація кольору теми
    serverHitboxClone.Color = currentThemeColor
    serverHitboxClone.Transparency = 0.6
end

local function updateServerHitbox()
    if not isServerHitboxEnabled then
        destroyServerHitboxClone()
        if serverHitboxRenderBound then
            pcall(function() RS:UnbindFromRenderStep("AbaddonServerHitbox") end)
            serverHitboxRenderBound = false
        end
        return
    end

    if not serverHitboxClone then
        task.spawn(createServerHitboxClone)
    end

    if not serverHitboxRenderBound then
        RS:BindToRenderStep("AbaddonServerHitbox", 1, function()
            if not isServerHitboxEnabled then
                RS:UnbindFromRenderStep("AbaddonServerHitbox")
                serverHitboxRenderBound = false
                return
            end
            serverHitboxRecord()
            serverHitboxApply()
        end)
        serverHitboxRenderBound = true
    end
end

