local wasAutokitPressing = false

local function autokitStep()
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    if isNearBrokenTable(root) then
        if wasAutokitPressing then
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game)
            wasAutokitPressing = false
        end
        return 
    end

    local COLLECT_RADIUS = 10 
    local shouldPressF = false

    if isAutokitEnabled then
        for prompt, _ in pairs(activePrompts) do
            if prompt and prompt.Parent and prompt.Enabled then
                local model = prompt.Parent
                local part = model:IsA("BasePart") and model or (model:FindFirstChild("Part") or model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart"))
                
                if part then
                    local distance = (root.Position - part.Position).Magnitude
                    if distance <= COLLECT_RADIUS then
                        prompt.RequiresLineOfSight = false
                        prompt.MaxActivationDistance = math.max(prompt.MaxActivationDistance, COLLECT_RADIUS + 5)
                        prompt.HoldDuration = autokitHoldDuration
                        shouldPressF = true
                    end
                end
            else
                activePrompts[prompt] = nil
            end
        end
    end

    if isElderAutokitEnabled then
        for prompt, _ in pairs(activeElderPrompts) do
            if prompt and prompt.Parent and prompt.Enabled then
                local model = prompt.Parent
                local part = model:IsA("BasePart") and model or (model:FindFirstChild("Part") or model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart"))

                if part then
                    local distance = (root.Position - part.Position).Magnitude
                    if distance <= COLLECT_RADIUS then
                        prompt.RequiresLineOfSight = false
                        prompt.MaxActivationDistance = math.max(prompt.MaxActivationDistance, COLLECT_RADIUS + 5)
                        prompt.HoldDuration = elderHoldDuration
                        shouldPressF = true
                    end
                end
            else
                activeElderPrompts[prompt] = nil
            end
        end
    end

    if shouldPressF then
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F, false, game)
        wasAutokitPressing = true
    elseif wasAutokitPressing then
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game)
        wasAutokitPressing = false
    end
end

