-- === PLAYER ESP ===
local function updatePlayerEsp()
    if not isPlayerEspEnabled then
        espFolderPlayers:ClearAllChildren()
        for _, p in pairs(game.Players:GetPlayers()) do
            if p.Character then
                local hl = p.Character:FindFirstChild("Abaddon_EspHighlight")
                if hl then hl:Destroy() end
            end
        end
        return
    end

    for _, targetPlayer in pairs(game.Players:GetPlayers()) do
        if targetPlayer ~= player then
            local char = targetPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") then
                local hum = char.Humanoid
                local root = char.HumanoidRootPart
                
                if hum.Health > 0 then
                    local teamColor = Color3.new(1,1,1)
                    if targetPlayer.Team then teamColor = targetPlayer.Team.TeamColor.Color end

                    local pName   = targetPlayer.Name
                    local ratio   = math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1)
                    local hpText  = math.floor(hum.Health) .. " / " .. math.floor(hum.MaxHealth)

                    -- =================================================
                    -- 3-D adornments: Box (BoxHandleAdornment), Outline
                    -- =================================================
                    if currentEspMode == "Box" then
                        local oldHl = espFolderPlayers:FindFirstChild(pName .. "_HL")
                        if oldHl then oldHl:Destroy() end
                        -- BoxHandleAdornment on HRP, same pattern as Milo ESP.
                        -- Size 3x6x3, offset down -3 so bottom face = feet.
                        -- AlwaysOnTop = true -> visible through walls.
                        local existingBox = espFolderPlayers:FindFirstChild(pName .. "_ESP")
                        if not existingBox then
                            local box = Instance.new("BoxHandleAdornment")
                            box.Name = pName .. "_ESP"
                            box.Adornee = root
                            box.AlwaysOnTop = true
                            box.ZIndex = 10
                            box.Transparency = 0.5
                            box.Color3 = teamColor
                            box.Size = Vector3.new(3, 6, 3)
                            box.CFrame = CFrame.new(0, 0, 0)
                            box.Parent = espFolderPlayers
                        else
                            if existingBox.Adornee ~= root then existingBox.Adornee = root end
                            existingBox.Color3 = teamColor
                            existingBox.Transparency = 0.5
                            existingBox.Size = Vector3.new(3, 6, 3)
                            existingBox.CFrame = CFrame.new(0, 0, 0)
                        end
                    elseif currentEspMode == "Outline" then
                        local oldBox = espFolderPlayers:FindFirstChild(pName .. "_ESP")
                        if oldBox then oldBox:Destroy() end
                        local hlName = pName .. "_HL"
                        local existingHl = espFolderPlayers:FindFirstChild(hlName)
                        -- Invalidate if: no adornee, adornee has no parent, OR adornee is no longer the current char
                        if existingHl and (
                            not existingHl.Adornee
                            or not existingHl.Adornee.Parent
                            or existingHl.Adornee ~= char
                        ) then
                            existingHl:Destroy(); existingHl = nil
                        end
                        if not existingHl then
                            pcall(function()
                                local h = Instance.new("Highlight")
                                h.Name = hlName
                                h.FillColor = teamColor
                                h.OutlineColor = teamColor
                                h.FillTransparency = 0.5
                                h.OutlineTransparency = 0
                                h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                                h.Adornee = char
                                h.Parent = espFolderPlayers
                                -- Auto-destroy when char leaves (respawn/death)
                                h.AncestryChanged:Connect(function()
                                    if h and h.Parent == espFolderPlayers then
                                        -- still alive in storage, check adornee validity
                                        if not h.Adornee or not h.Adornee.Parent then
                                            pcall(function() h:Destroy() end)
                                        end
                                    end
                                end)
                            end)
                        else
                            existingHl.Adornee = char
                            existingHl.FillColor = teamColor
                            existingHl.OutlineColor = teamColor
                        end
                    else
                        -- switching to 2-D mode: kill 3-D leftovers
                        local oldBox = espFolderPlayers:FindFirstChild(pName .. "_ESP")
                        if oldBox then oldBox:Destroy() end
                        local oldHl = espFolderPlayers:FindFirstChild(pName .. "_HL")
                        if oldHl then oldHl:Destroy() end
                    end

                    -- =================================================
                    -- UNIFIED _BB: one BillboardGui per player for ALL
                    -- 2-D content (HP bar + mode visual).
                    -- Layout (top = further above head in world):
                    --   y 0..22  -> HpSection  (Visible = isEspHpEnabled)
                    --   y 24..end-> mode visual
                    --
                    -- Sizes:
                    --   Box/Outline : w=84 h=24 studY=5.2  (HP only)
                    --   Label       : w=84 h=46 studY=3.5
                    --   Label2      : w=56 h=104 studY=0.5
                    --   Point       : w=84 h=64 studY=3.0
                    -- =================================================
                    local bbName = pName .. "_BB"
                    local bb = espFolderPlayers:FindFirstChild(bbName)

                    -- Invalidate if adornee gone or mode changed
                    if bb then
                        if not bb.Adornee or not bb.Adornee.Parent then
                            bb:Destroy(); bb = nil
                        elseif bb:GetAttribute("EspMode") ~= currentEspMode then
                            bb:Destroy(); bb = nil
                        end
                    end

                    local bbW, bbH, bbStudY
                    if currentEspMode == "Box" or currentEspMode == "Outline" then
