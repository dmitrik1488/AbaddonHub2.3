local function checkPanicCircle()
    if not isPanicCircleEnabled then 
        stopPanicAlarm()
        return 
    end
    
    updatePanicCircleVisual()

    local intruderFound = false
    local currentIntruders = {} 
    
    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local myPos = player.Character.HumanoidRootPart.Position

        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= player then
                local isEnemy = true
                if player.Team and p.Team and player.Team == p.Team then
                    isEnemy = false
                end
                
                if isEnemy and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") then
                     local hum = p.Character.Humanoid
                     if hum.Health > 0 then
                        local enemyPos = p.Character.HumanoidRootPart.Position
                        local dist = (enemyPos - myPos).Magnitude
                        
                        if dist <= panicCircleRadius then
                            intruderFound = true
                            currentIntruders[p] = true
                        end
                     end
                end
            end
        end
    end
    
    updatePanicHighlights(currentIntruders)
    
    if intruderFound then
        if not panicCircleSound or not panicCircleSound.Parent then
             panicCircleSound = Instance.new("Sound", game.SoundService)
             panicCircleSound.Name = PANIC_SOUND_NAME
             panicCircleSound.SoundId = "rbxassetid://140324537123195"
             panicCircleSound.Volume = panicCircleVolume
             panicCircleSound.Looped = true
        end
        if not panicCircleSound.IsPlaying then panicCircleSound:Play() end
    else
        stopPanicAlarm()
    end
end

