local function toggleTaliyah(state)
    isTaliyahEnabled = state
    if state then
        -- Restore persisted wave from getgenv on reinject
        if type(getgenv()._taliyahWave) == "number" and getgenv()._taliyahWave > taliyahWave then
            taliyahWave         = getgenv()._taliyahWave
            taliyahBasePriceIdx = getgenv()._taliyahBase or (20 + taliyahWave * 10)
            taliyahMaxIdx       = getgenv()._taliyahMax  or math.min(30 + taliyahWave * 43, 1200)
        end
        createTaliyahGui()
    else
        if taliyahConnection then
            pcall(function() taliyahConnection:Disconnect() end)
            taliyahConnection = nil
        end
        if taliyahGui then
            pcall(function() taliyahGui:Destroy() end)
            taliyahGui = nil
        end
        taliyahGuiRefs       = {}
        taliyahIsInitialized = false
    end
end


