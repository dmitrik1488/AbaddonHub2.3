local function updateScanner()
    if targetInfoGui then
        if currentTarget and isTargetInfoEnabled then
            targetInfoGui.Visible = true
            local hum = currentTarget.Parent and currentTarget.Parent:FindFirstChild("Humanoid")
            if hum then
                targetInfoGui:FindFirstChild("NameLabel").Text = currentTarget.Parent.Name

                -- Плавний HP повзунок
                local realRatio = math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1)
                if scannerDisplayHp == nil then scannerDisplayHp = realRatio end

                -- Плавно наближаємо до реального значення
                scannerDisplayHp = scannerDisplayHp + (realRatio - scannerDisplayHp) * 0.12
                if math.abs(scannerDisplayHp - realRatio) < 0.001 then
                    scannerDisplayHp = realRatio
                end

                local fillFrame = targetInfoGui:FindFirstChild("HPFill", true)
                if fillFrame then
                    fillFrame.Size = UDim2.new(scannerDisplayHp, 0, 1, 0)
                end

                local hpText = targetInfoGui:FindFirstChild("HPText", true)
                if hpText then
                    hpText.Text = math.floor(hum.Health) .. " / " .. math.floor(hum.MaxHealth)
                end

                -- Перевірка урону → запуск обертання
                if scannerLastHp ~= nil and hum.Health < scannerLastHp then
                    scannerIsSpinning = true
                end
                scannerLastHp = hum.Health
            end
        elseif isMenuOpen and isTargetInfoEnabled then
            targetInfoGui.Visible = true
            targetInfoGui:FindFirstChild("NameLabel").Text = "Target: NULL"
            local fillFrame = targetInfoGui:FindFirstChild("HPFill", true)
            if fillFrame then fillFrame.Size = UDim2.new(1, 0, 1, 0) end
            local hpText = targetInfoGui:FindFirstChild("HPText", true)
            if hpText then hpText.Text = "100/100" end
        else
            targetInfoGui.Visible = false
        end
    end

    if not isTargetScannerEnabled then
        currentTarget = nil
        destroyLockVisuals()
        scannerIsSpinning = false
        scannerLastHp = nil
        scannerDisplayHp = nil
        scannerRotation = 0
        return
    end

    -- Валідація цілі
    if currentTarget then
        local hum = currentTarget.Parent and currentTarget.Parent:FindFirstChild("Humanoid")
        if not currentTarget.Parent or not hum or hum.Health <= 0 then
            currentTarget = nil
            destroyLockVisuals()
            scannerIsSpinning = false
            scannerLastHp = nil
            scannerDisplayHp = nil
        end
    end

    -- Пошук цілі в конусі камери (до 30 студів)
    local myChar = player.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if myRoot then
        local camLook = camera.CFrame.LookVector
        local camPos  = camera.CFrame.Position
        local SCAN_RANGE = 30
        local LOOK_DOT   = 0.92
        local bestTarget = nil
        local bestDot    = -1

        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= player and p.Character then
                local root = p.Character:FindFirstChild("HumanoidRootPart")
                local hum  = p.Character:FindFirstChild("Humanoid")
                local isTeammate = player.Team and p.Team and player.Team == p.Team
                if root and hum and hum.Health > 0 and not isTeammate then
                    local dist = (root.Position - myRoot.Position).Magnitude
                    if dist <= SCAN_RANGE then
                        local toTarget = (root.Position - camPos).Unit
                        local dot = camLook:Dot(toTarget)
                        if dot >= LOOK_DOT and dot > bestDot then
                            bestDot    = dot
                            bestTarget = root
                        end
                    end
                end
            end
        end

        if bestTarget and bestTarget ~= currentTarget then
            currentTarget   = bestTarget
            scannerLastHp   = nil
            scannerDisplayHp = nil
            scannerIsSpinning = false
            scannerRotation = 0
            createScanner(currentTarget)
        end
        if not bestTarget and not currentTarget then
            destroyLockVisuals()
        end
    end

    if scannerGui and currentTarget then
        scannerGui.Adornee = currentTarget

        local myChar2 = player.Character
        local myRoot2 = myChar2 and myChar2:FindFirstChild("HumanoidRootPart")
        if myRoot2 then
            local dist = (currentTarget.Position - myRoot2.Position).Magnitude
            local container = scannerGui:FindFirstChild("ScannerContainer")
            if container then
                container.Visible = (dist <= 50)
            end
        end

        -- Постійне обертання поки є ціль, швидше при урозі
        local container = scannerGui:FindFirstChild("ScannerContainer")
        if container then
            local speed = scannerIsSpinning and (360 / 1.5) or (360 / 5)
            local dt = 1 / 60
            scannerRotation = scannerRotation + speed * dt
            if scannerRotation >= 360 then
                scannerRotation = scannerRotation - 360
            end
            container.Rotation = scannerRotation

            -- Синхронізація кольору теми
            local img = container:FindFirstChild("CrosshairImage")
            if img then
                img.ImageColor3 = currentThemeColor
            end
        end
    end
end

