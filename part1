local function ensureNotifGui()
    if notifGui and notifGui.Parent then return end
    notifGui = Instance.new("ScreenGui", player.PlayerGui)
    notifGui.Name = "Abaddon_NotifSystem"
    notifGui.ResetOnSpawn = false
    notifGui.IgnoreGuiInset = true
    notifGui.DisplayOrder = 1000000
end

local function repositionNotifs()
    local screenH = camera.ViewportSize.Y
    local baseY = screenH - 175
    for i = #notifStack, 1, -1 do
        local f = notifStack[i].frame
        if f and f.Parent then
            local targetY = baseY - notifCfg.h
            TS:Create(f, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {
                Position = UDim2.new(1, -(notifCfg.w + 16), 0, targetY)
            }):Play()
            baseY = baseY - notifCfg.h - notifCfg.gap
        end
    end
end

local function removeNotif(entry)
    for i, e in ipairs(notifStack) do
        if e == entry then
            table.remove(notifStack, i)
            break
        end
    end
    if entry.frame and entry.frame.Parent then
        TS:Create(entry.frame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Position = UDim2.new(1, 16, entry.frame.Position.Y.Scale, entry.frame.Position.Y.Offset)
        }):Play()
        task.delay(0.35, function()
            if entry.frame and entry.frame.Parent then entry.frame:Destroy() end
        end)
    end
    task.delay(0.35, repositionNotifs)
end

-- showNotification(title, lines)
-- lines = array of { text = string, color = Color3 (optional) }
local function showNotification(title, lines)
    if not _hubActive then return end
    ensureNotifGui()

    local screenH = camera.ViewportSize.Y
    local startY = screenH - 175  -- off-screen start (above buttons)

    local f = Instance.new("TextButton", notifGui)
    f.Size = UDim2.new(0, notifCfg.w, 0, notifCfg.h)
    f.Position = UDim2.new(1, 16, 0, startY - notifCfg.h)  -- starts off right
    f.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
    f.BackgroundTransparency = 0.15
    f.BorderSizePixel = 0
    f.ClipsDescendants = true
    f.Text = ""
    f.AutoButtonColor = false
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 12)

    -- Left accent bar
    local accent = Instance.new("Frame", f)
    accent.Size = UDim2.new(0, 3, 1, 0)
    accent.BackgroundColor3 = currentThemeColor
    accent.BorderSizePixel = 0
    Instance.new("UICorner", accent).CornerRadius = UDim.new(0, 12)

    -- Stroke
    local stroke = Instance.new("UIStroke", f)
    stroke.Color = currentThemeColor
    stroke.Thickness = 1.2
    stroke.Transparency = 0.55

    -- Title
    local titleLbl = Instance.new("TextLabel", f)
    titleLbl.Size = UDim2.new(1, -16, 0, 20)
    titleLbl.Position = UDim2.new(0, 12, 0, 7)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = title
    titleLbl.TextColor3 = currentThemeColor
    titleLbl.Font = Enum.Font.GothamBold
    titleLbl.TextSize = 14
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left

    -- Message lines
    local lineY = 30
    for _, line in ipairs(lines) do
        local lbl = Instance.new("TextLabel", f)
        lbl.Size = UDim2.new(1, -16, 0, 18)
        lbl.Position = UDim2.new(0, 12, 0, lineY)
        lbl.BackgroundTransparency = 1
        lbl.Font = Enum.Font.GothamBold
        lbl.TextSize = 15
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.TextColor3 = line.color or Color3.new(1, 1, 1)
        lbl.Text = line.text
        lineY = lineY + 18
    end

    -- Progress bar background
    local barBg = Instance.new("Frame", f)
    barBg.Size = UDim2.new(1, 0, 0, 3)
    barBg.Position = UDim2.new(0, 0, 1, -3)
    barBg.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    barBg.BorderSizePixel = 0

    -- Progress bar fill (theme color, animates left → right, then disappears)
    local barFill = Instance.new("Frame", barBg)
    barFill.Size = UDim2.new(0, 0, 1, 0)
    barFill.BackgroundColor3 = currentThemeColor
    barFill.BorderSizePixel = 0
    Instance.new("UICorner", barFill).CornerRadius = UDim.new(0, 2)

    local entry = { frame = f }
    -- Click to dismiss
    f.MouseButton1Click:Connect(function()
        removeNotif(entry)
    end)
    table.insert(notifStack, entry)

    -- Slide in from right
