local function staffUntrackAll()
    for uid, conn in pairs(staffPlayerConns) do
        pcall(function() conn:Disconnect() end)
        staffPlayerConns[uid] = nil
    end
    if staffPlayerAddedConn then
        pcall(function() staffPlayerAddedConn:Disconnect() end)
        staffPlayerAddedConn = nil
    end
end

local function toggleStaffStats(state)
    isStaffStatsEnabled = state
    if state then
        createStaffStatsWindow()

        local function trackPlayer(p)
            -- Disconnect any existing connection for this player first
            if staffPlayerConns[p.UserId] then
                pcall(function() staffPlayerConns[p.UserId]:Disconnect() end)
                staffPlayerConns[p.UserId] = nil
            end
            -- Record current team color if not already spectator
            if p.Team and p.Team.Name ~= "Spectators" then
                staffPrevTeamColor[p.UserId] = p.Team.TeamColor.Color
            end
            staffPlayerConns[p.UserId] = p:GetPropertyChangedSignal("Team"):Connect(function()
                if p.Team and p.Team.Name == "Spectators" then
                    local nameColor = staffPrevTeamColor[p.UserId] or Color3.new(1, 1, 1)
                    task.spawn(function()
                        showNotification("Staff Statistics", {
                            { text = p.DisplayName .. " joined spectators", color = Color3.new(0.85, 0.85, 1) },
                            { text = p.Name, color = nameColor },
                        })
                    end)
                elseif p.Team and p.Team.Name ~= "Spectators" then
                    staffPrevTeamColor[p.UserId] = p.Team.TeamColor.Color
                end
            end)
        end

        -- Disconnect stale PlayerAdded listener before adding a new one
        if staffPlayerAddedConn then
            pcall(function() staffPlayerAddedConn:Disconnect() end)
        end

        for _, p in pairs(game.Players:GetPlayers()) do
            trackPlayer(p)
        end
        staffPlayerAddedConn = game.Players.PlayerAdded:Connect(function(p)
            task.delay(1, function() trackPlayer(p) end)
        end)

        staffStatsConnection = RS.RenderStepped:Connect(function() if tick()%0.5 < 0.1 then updateStaffStatsList() end end)
    else
        staffUntrackAll()
        if staffStatsConnection then staffStatsConnection:Disconnect(); staffStatsConnection=nil end
        if staffStatsGui then staffStatsGui:Destroy(); staffStatsGui=nil end
    end
end

