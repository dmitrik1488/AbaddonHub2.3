-- === AUTO VOID DROP ===
local VOID_RESOURCES = {["iron"]=true,["diamond"]=true,["emerald"]=true}

local function voidDropInit()
    -- Cache remote and inventory folder
    pcall(function()
        local nm = ReplicatedStorage:WaitForChild("rbxts_include",2)
            :WaitForChild("node_modules",2):WaitForChild("@rbxts",2)
            :WaitForChild("net",2):WaitForChild("out",2):WaitForChild("_NetManaged",2)
        voidDropRemote = nm and nm:FindFirstChild("DropItem")
        voidInventoryFolder = ReplicatedStorage:FindFirstChild("Inventories")
            and ReplicatedStorage.Inventories:FindFirstChild(player.Name)
    end)
end

local function voidDropTick()
    if not isVoidDropEnabled then return end
    if not voidDropRemote or not voidInventoryFolder then return end
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    -- Only trigger when player is below the configured Y threshold
    if hrp.Position.Y > voidDropHeight then return end
    -- Drop all configured resources
    for _, item in pairs(voidInventoryFolder:GetChildren()) do
        if VOID_RESOURCES[string.lower(item.Name)] then
            local amt = 1000
            pcall(function()
                if item:IsA("IntValue") or item:IsA("NumberValue") then
                    amt = item.Value
                elseif item:GetAttribute("Amount") then
                    amt = item:GetAttribute("Amount")
                elseif item:FindFirstChild("Amount") then
                    amt = item.Amount.Value
                end
            end)
            pcall(function()
                voidDropRemote:InvokeServer({item=item, amount=amt})
            end)
            task.wait(voidDropDelay)
        end
    end
end

local function toggleVoidDrop(state)
    isVoidDropEnabled = state
    if state then
        task.spawn(voidDropInit)  -- non-blocking: WaitForChild runs in background
        if not voidDropConnection then
            voidDropConnection = RunService.Heartbeat:Connect(voidDropTick)
        end
    else
        if voidDropConnection then
            voidDropConnection:Disconnect(); voidDropConnection = nil
        end
    end
end

