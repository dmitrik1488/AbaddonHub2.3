                                if f then f.Size = UDim2.new(ratio,0,1,0); f.BackgroundColor3 = teamColor end
                            end
                        end

                        if currentEspMode == "Label" then
                            local nl = bb:FindFirstChild("NameLbl")
                            if nl then nl.TextColor3 = teamColor end
                            local nbg = bb:FindFirstChild("NameBarBG")
                            if nbg then
                                local f = nbg:FindFirstChild("HPFill")
                                if f then f.Size = UDim2.new(ratio,0,1,0); f.BackgroundColor3 = teamColor end
                            end
                        elseif currentEspMode == "Label2" then
                            local rect = bb:FindFirstChild("Rect")
                            if rect then
                                for _, l in rect:GetChildren() do
                                    if l:IsA("Frame") then l.BackgroundColor3 = teamColor end
                                end
                            end
                        elseif currentEspMode == "Point" then
                            local od = bb:FindFirstChild("OuterDiamond")
                            if od then od.BackgroundColor3 = teamColor end
                        end
                    end

                else
                    -- Player is dead or left: clean up everything
                    local oldBox = espFolderPlayers:FindFirstChild(targetPlayer.Name .. "_ESP")
                    if oldBox then oldBox:Destroy() end
                    local oldHl = espFolderPlayers:FindFirstChild(targetPlayer.Name .. "_HL")
                    if oldHl then oldHl:Destroy() end
                    local oldBb = espFolderPlayers:FindFirstChild(targetPlayer.Name .. "_BB")
                    if oldBb then oldBb:Destroy() end
                    -- legacy cleanup
                    for _, suffix in ipairs({"_LBL","_LBL2","_PT","_HPBB"}) do
                        local old = espFolderPlayers:FindFirstChild(targetPlayer.Name .. suffix)
                        if old then old:Destroy() end
                    end
                    local oldHlChar = char:FindFirstChild("Abaddon_EspHighlight")
                    if oldHlChar then oldHlChar:Destroy() end
                end
            end
        end
    end
end

