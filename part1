    -- Delay slider 0.0 - 1.0
    local function makeSl(parent, lbl, syncKey, minV, maxV, step, getV, setV)
        local fr=Instance.new("Frame",parent); fr.Size=UDim2.new(1,0,0,30); fr.BackgroundTransparency=1
        local ll=Instance.new("TextLabel",fr); ll.Size=UDim2.new(1,0,0,14); ll.BackgroundTransparency=1
        ll.TextColor3=Color3.new(1,1,1); ll.Font=Enum.Font.GothamBold; ll.TextSize=10
        ll.TextXAlignment=Enum.TextXAlignment.Left
        local function fmt(v) return string.format("%.1f",v) end
        ll.Text=lbl..": "..fmt(getV())
        local bg=Instance.new("TextButton",fr); bg.Size=UDim2.new(1,0,0,10); bg.Position=UDim2.new(0,0,0,18)
        bg.BackgroundColor3=Color3.fromRGB(40,40,40); bg.BackgroundTransparency=0.5
        bg.AutoButtonColor=false; bg.Text=""; bg.BorderSizePixel=0
        Instance.new("UICorner",bg).CornerRadius=UDim.new(1,0)
        local fill=Instance.new("Frame",bg); fill.Name="SliderFill"
        fill.Size=UDim2.new(math.clamp((getV()-minV)/(maxV-minV),0,1),0,1,0)
        fill.BackgroundColor3=currentThemeColor; fill.BorderSizePixel=0
        Instance.new("UICorner",fill).CornerRadius=UDim.new(1,0)
        local drag=false
        local function applyV(v)
            v = math.clamp(v, minV, maxV)
            setV(v)
            fill.Size=UDim2.new(math.clamp((v-minV)/(maxV-minV),0,1),0,1,0)
            ll.Text=lbl..": "..fmt(v)
        end
        -- sliderSync so config restore updates UI
        if syncKey then
            sliderSyncFns[syncKey] = function(v) applyV(v) end
        end
        bg.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end
        end)
        bg.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
        end)
        -- Use MouseMoved on bg for reliable delta (works even when fast)
        bg.MouseMoved:Connect(function(x, y)
            if drag then
                local sz = bg.AbsoluteSize.X
                if sz < 1 then return end
                local rx=math.clamp((x - 0) / sz, 0, 1)  -- x is relative to element
                local v=minV+math.floor(rx*(maxV-minV)/step+0.5)*step
                applyV(v)
            end
        end)
        -- Fallback: UIS for when mouse leaves the button
        UIS.InputChanged:Connect(function(i)
            if drag and i.UserInputType==Enum.UserInputType.MouseMovement then
                local sz = bg.AbsoluteSize.X
                if sz < 1 then return end
                local rx=math.clamp((i.Position.X-bg.AbsolutePosition.X)/sz,0,1)
                local v=minV+math.floor(rx*(maxV-minV)/step+0.5)*step
                applyV(v)
            end
        end)
        return fill, ll
    end

