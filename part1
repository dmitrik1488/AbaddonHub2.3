local function createMainHud()
    if mainHudGui then mainHudGui:Destroy() end
    local sg = Instance.new("ScreenGui")
    sg.Name = "Abaddon_MainHud"
    sg.ResetOnSpawn = false
    sg.DisplayOrder = 99
    sg.Parent = player.PlayerGui

    -- Touches top edge: position Y=0, corners only rounded on bottom
    local frame = Instance.new("Frame", sg)
    frame.Name = "HudFrame"
    frame.Size = UDim2.new(0, 290, 0, 44)
    frame.Position = UDim2.new(0.5, -145, 0, 0)
    frame.BackgroundColor3 = menuBgColor
    frame.BackgroundTransparency = menuBgTransparency
    frame.BorderSizePixel = 0
    local corner = Instance.new("UICorner", frame)
    corner.CornerRadius = UDim.new(0, 10)

    -- Theme accent line at very bottom
    local accent = Instance.new("Frame", frame)
    accent.Name = "AccentLine"
    accent.Size = UDim2.new(1, 0, 0, 2)
    accent.Position = UDim2.new(0, 0, 1, -2)
    accent.BackgroundColor3 = currentThemeColor
    accent.BorderSizePixel = 0

    -- DisplayName
    local nameLabel = Instance.new("TextLabel", frame)
    nameLabel.Name = "NameLabel"
    nameLabel.Size = UDim2.new(0.52, -10, 0.52, 0)
    nameLabel.Position = UDim2.new(0, 10, 0, 4)
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextColor3 = currentThemeColor
    nameLabel.Font = Enum.Font.GothamBlack
    nameLabel.TextSize = 14
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
    nameLabel.Text = player.DisplayName

    -- HWID
    local hwidLabel = Instance.new("TextLabel", frame)
    hwidLabel.Name = "HwidLabel"
    hwidLabel.Size = UDim2.new(0.52, -10, 0.42, 0)
    hwidLabel.Position = UDim2.new(0, 10, 0.54, 0)
    hwidLabel.BackgroundTransparency = 1
    hwidLabel.TextColor3 = Color3.fromRGB(160, 170, 180)
    hwidLabel.Font = Enum.Font.Gotham
    hwidLabel.TextSize = 11
    hwidLabel.TextXAlignment = Enum.TextXAlignment.Left
    hwidLabel.Text = "HWID: " .. mainHudHWID

    -- Vertical dividers
    local function makDiv(xScale)
        local d = Instance.new("Frame", frame)
        d.Size = UDim2.new(0, 1, 0.65, 0)
        d.Position = UDim2.new(xScale, 0, 0.175, 0)
        d.BackgroundColor3 = currentThemeColor
        d.BackgroundTransparency = 0.5
        d.BorderSizePixel = 0
        return d
    end
    local divL = makDiv(0.535)
    local divR = makDiv(0.775)

    -- FPS block
    local fpsLbl = Instance.new("TextLabel", frame)
    fpsLbl.Name = "FpsLbl"
    fpsLbl.Size = UDim2.new(0.235, 0, 0.45, 0)
    fpsLbl.Position = UDim2.new(0.55, 0, 0.06, 0)
    fpsLbl.BackgroundTransparency = 1
    fpsLbl.TextColor3 = currentThemeColor
    fpsLbl.Font = Enum.Font.GothamBold
    fpsLbl.TextSize = 11
    fpsLbl.Text = "FPS"

    local fpsVal = Instance.new("TextLabel", frame)
    fpsVal.Name = "FpsVal"
    fpsVal.Size = UDim2.new(0.235, 0, 0.45, 0)
    fpsVal.Position = UDim2.new(0.55, 0, 0.5, 0)
    fpsVal.BackgroundTransparency = 1
    fpsVal.TextColor3 = Color3.new(1,1,1)
    fpsVal.Font = Enum.Font.GothamBlack
    fpsVal.TextSize = 13
    fpsVal.Text = "0"

    -- PING block
    local pingLbl = Instance.new("TextLabel", frame)
    pingLbl.Name = "PingLbl"
    pingLbl.Size = UDim2.new(0.22, 0, 0.45, 0)
    pingLbl.Position = UDim2.new(0.79, 0, 0.06, 0)
    pingLbl.BackgroundTransparency = 1
    pingLbl.TextColor3 = currentThemeColor
    pingLbl.Font = Enum.Font.GothamBold
    pingLbl.TextSize = 11
    pingLbl.Text = "PING"

    local pingVal = Instance.new("TextLabel", frame)
    pingVal.Name = "PingVal"
    pingVal.Size = UDim2.new(0.22, 0, 0.45, 0)
    pingVal.Position = UDim2.new(0.79, 0, 0.5, 0)
    pingVal.BackgroundTransparency = 1
    pingVal.TextColor3 = Color3.new(1,1,1)
    pingVal.Font = Enum.Font.GothamBlack
    pingVal.TextSize = 11
    pingVal.Text = "0ms"

	makeDraggable(frame, true)
    applyLayoutPos(frame)
    savedWindowPositions[frame] = frame.Position
    mainHudGui = sg

    -- FPS counter
    local lastT = tick()
    RS.RenderStepped:Connect(function()
        local now = tick(); local dt = now - lastT; lastT = now
        if dt > 0 then mainHudFps = math.floor(1 / dt) end
    end)

    -- Update loop 0.5s
    task.spawn(function()
        while mainHudGui and mainHudGui.Parent do
            if isMainHudEnabled then
                pcall(function()
                    mainHudPing = math.floor(game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue())
                end)
                fpsVal.Text = tostring(mainHudFps)
                fpsVal.TextColor3 = mainHudFps >= 55 and Color3.fromRGB(80,255,80)
                    or mainHudFps >= 30 and Color3.fromRGB(255,200,0) or Color3.fromRGB(255,60,60)
                pingVal.Text = tostring(mainHudPing).."ms"
                pingVal.TextColor3 = mainHudPing < 80 and Color3.fromRGB(80,255,80)
                    or mainHudPing < 150 and Color3.fromRGB(255,200,0) or Color3.fromRGB(255,60,60)
                -- sync theme
                accent.BackgroundColor3 = currentThemeColor
                nameLabel.TextColor3 = currentThemeColor
                fpsLbl.TextColor3 = currentThemeColor
                pingLbl.TextColor3 = currentThemeColor
                divL.BackgroundColor3 = currentThemeColor
                divR.BackgroundColor3 = currentThemeColor
            end
            task.wait(0.5)
        end
    end)
end

local function toggleMainHud(state)
    isMainHudEnabled = state
    if state then
        if not mainHudGui then createMainHud() end
        mainHudGui.Enabled = true
    else
        if mainHudGui then mainHudGui.Enabled = false end
    end
end


